generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Motorista {
  id       Int     @id @default(autoincrement())
  nome     String
  cpf      String  @unique
  telefone String?
  rntrc    String?
  status   String  @default("ATIVO")

  veiculos Veiculo[]
  cargas   Carga[]
}

model Veiculo {
  id          Int       @id @default(autoincrement())
  placa       String    @unique
  tipo        String
  carroceria  String
  motoristaId Int
  motorista   Motorista @relation(fields: [motoristaId], references: [id])
}

model Carga {
  id          Int      @id @default(autoincrement())
  cliente     String
  origem      String
  destino     String
  peso        Float
  tipoVeiculo String?
  status      String   @default("PENDENTE")
  createdAt   DateTime @default(now())

  motoristaId Int?
  motorista   Motorista? @relation(fields: [motoristaId], references: [id])

  frete    Frete?
  entregas Entrega[]
}

model Frete {
  id             Int   @id @default(autoincrement())
  cargaId        Int   @unique
  valorEmpresa   Float
  valorMotorista Float
  margem         Float
  pedagio        Float?
  custoExtra     Float?

  carga Carga @relation(fields: [cargaId], references: [id])
}

model Entrega {
  id      Int    @id @default(autoincrement())
  cidade  String
  estado  String
  peso    Float

  cargaId Int
  carga   Carga @relation(fields: [cargaId], references: [id])
}

model TabelaFrete {
  id                 String @id @default(uuid())
  origem             String
  destino            String
  tipoVeiculo        String
  valorMotoristaBase Float
  pedagio            Float?
  icmsPercentual     Float?
  custoExtra         Float?
  observacao         String?
}