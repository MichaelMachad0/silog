generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Motorista {
  id            String   @id @default(uuid())
  nome          String
  cpf           String   @unique
  telefone      String?
  cnh           String?
  validadeCNH   DateTime?
  status        String   @default("ATIVO")

  veiculos      Veiculo[]
  cargas        Carga[]

  createdAt     DateTime @default(now())
}

model Veiculo {
  id        String   @id @default(uuid())
  placa     String   @unique
  tipo      String
  marca     String?
  modelo    String?
  ano       Int?

  motoristaId String
  motorista   Motorista @relation(fields: [motoristaId], references: [id])

  cargas     Carga[]

  createdAt  DateTime @default(now())
}

model Carga {
  id            String   @id @default(uuid())
  origem        String
  destino       String
  peso          Float?
  valorNota     Float?

  motoristaId   String
  motorista     Motorista @relation(fields: [motoristaId], references: [id])

  veiculoId     String
  veiculo       Veiculo @relation(fields: [veiculoId], references: [id])

  frete         Frete?

  createdAt     DateTime @default(now())
}

model Frete {
  id              String   @id @default(uuid())
  valorEmpresa    Float
  valorMotorista  Float
  impostos        Float?
  lucro           Float?

  cargaId         String   @unique
  carga           Carga @relation(fields: [cargaId], references: [id])

  createdAt       DateTime @default(now())
}