generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusCarga {
  CRIADA
  LIBERADA
  EM_TRANSITO
  ENTREGUE
  CANCELADA
}

enum StatusMensagem {
  PENDENTE
  ENVIADA
  FALHA
  IGNORADA
}

model Motorista {
  id            String   @id @default(uuid())
  nome          String
  cpf           String   @unique
  telefone      String?
  cnh           String?
  validadeCNH   DateTime?
  status        String   @default("ATIVO")

  veiculos      Veiculo[]
  cargas        Carga[]

  createdAt     DateTime @default(now())
}

model Veiculo {
  id        String   @id @default(uuid())
  placa     String   @unique
  tipo      String
  marca     String?
  modelo    String?
  ano       Int?

  motoristaId String
  motorista   Motorista @relation(fields: [motoristaId], references: [id])

  cargas     Carga[]

  createdAt  DateTime @default(now())
}

model Carga {
  id            String      @id @default(uuid())
  origem        String
  destino       String
  peso          Float?
  valorNota     Float?
  status        StatusCarga @default(CRIADA)
  rastreadoEm   DateTime?
  entregueEm    DateTime?

  motoristaId   String
  motorista     Motorista @relation(fields: [motoristaId], references: [id])

  veiculoId     String
  veiculo       Veiculo @relation(fields: [veiculoId], references: [id])

  frete         Frete?
  eventos       CargaEvento[]
  mensagens     MensagemLog[]

  createdAt     DateTime @default(now())
}

model CargaEvento {
  id             String       @id @default(uuid())
  cargaId        String
  carga          Carga        @relation(fields: [cargaId], references: [id], onDelete: Cascade)
  statusAnterior StatusCarga?
  statusNovo     StatusCarga
  observacao     String?
  createdAt      DateTime     @default(now())
  mensagem       MensagemLog?

  @@index([cargaId])
}

model MensagemLog {
  id            String         @id @default(uuid())
  cargaId       String
  carga         Carga          @relation(fields: [cargaId], references: [id], onDelete: Cascade)
  cargaEventoId String?        @unique
  cargaEvento   CargaEvento?   @relation(fields: [cargaEventoId], references: [id], onDelete: SetNull)
  telefone      String
  conteudo      String
  status        StatusMensagem @default(PENDENTE)
  providerId    String?
  erro          String?
  createdAt     DateTime       @default(now())
  enviadaEm     DateTime?

  @@index([cargaId])
}

model Frete {
  id              String   @id @default(uuid())
  valorEmpresa    Float
  valorMotorista  Float
  impostos        Float?
  lucro           Float?

  cargaId         String   @unique
  carga           Carga @relation(fields: [cargaId], references: [id])

  createdAt       DateTime @default(now())
}