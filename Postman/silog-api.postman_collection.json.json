				{
					"name": "Criar Motorista",
					"event": [
						{
							"listen": "test",
							"script": {
								"id": "383d8bbe-64d9-467b-a078-4b664505a1bb",
								"exec": [
									"pm.test(\"Status 201 - Motorista criado\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Resposta contém ID do motorista\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property(\"id\");",
									"    pm.collectionVariables.set(\"motorista_id\", json.id);",
									"    pm.environment.set(\"motorista_id\", json.id);",
									"});",
									"",
									"pm.test(\"Dados do motorista retornados corretamente\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.nome).to.eql(\"João Silva Teste\");",
									"    pm.expect(json.cpf).to.eql(\"98765432100\");",
									"});",
									"",
									"pm.test(\"Tempo de resposta menor que 2000ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(2000);",
									"});"
								],
