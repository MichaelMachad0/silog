		{
			"name": "Motoristas",
			"item": [
				{
					"name": "Listar Motoristas",
					"event": [
						{
							"listen": "test",
							"script": {
								"id": "578cd570-67dc-4ed3-a21d-13276c6c393d",
								"exec": [
									"pm.test(\"Status 200 - Lista retornada com sucesso\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Resposta é um array\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.be.an(\"array\");",
									"});",
									"",
									"pm.test(\"Motoristas possuem campos obrigatórios\", function () {",
									"    const json = pm.response.json();",
									"    if (json.length > 0) {",
									"        pm.expect(json[0]).to.have.property(\"id\");",
									"        pm.expect(json[0]).to.have.property(\"nome\");",
									"        pm.expect(json[0]).to.have.property(\"cpf\");",
									"    }",
									"});",
									"",
									"pm.test(\"Tempo de resposta menor que 2000ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(2000);",
									"});"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
