									"pm.test(\"Status 200 - Motorista atualizado\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Resposta contém ID do motorista\", function () {",
									"    let json;",
									"    try {",
									"        json = pm.response.json();",
									"    } catch (e) {",
									"        pm.expect.fail(\"Resposta não é um JSON válido: \" + e.message);",
									"        return;",
									"    }",
									"    pm.expect(json).to.have.property(\"id\");",
									"});",
									"",
									"pm.test(\"Dados atualizados corretamente\", function () {",
									"    let json;",
									"    try {",
									"        json = pm.response.json();",
									"    } catch (e) {",
									"        pm.expect.fail(\"Resposta não é um JSON válido: \" + e.message);",
									"        return;",
									"    }",
									"    pm.expect(json.nome).to.eql(\"Carlos Freitas Atualizado\");",
									"    pm.expect(json.cpf).to.eql(\"12345678911\");",
									"    pm.expect(json.telefone).to.eql(\"71988888888\");",
									"    pm.expect(json.cnh).to.eql(\"1234567890\");",
									"});",
									"",
									"pm.test(\"Tempo de resposta menor que 2000ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(2000);",
